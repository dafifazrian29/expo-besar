import"./hoisted.7907c777.js";document.querySelectorAll(".accordion-button").forEach(e=>{e.addEventListener("click",()=>{e.classList.toggle("active");const t=e.nextElementSibling;t.style.display==="block"?t.style.display="none":t.style.display="block"})});function d(){const e=document.getElementById("upButton");document.body.scrollTop>100||document.documentElement.scrollTop>100?e.classList.add("show"):e.classList.remove("show")}function i(){window.scrollTo({top:0,behavior:"smooth"})}window.addEventListener("scroll",d);document.getElementById("upButton").addEventListener("click",i);document.addEventListener("DOMContentLoaded",function(){const e=document.querySelectorAll(".illustration-item"),t=document.getElementById("loadMoreBtn"),l=20;e.forEach((n,o)=>{o>=l&&n.classList.add("hidden")}),e.length<=l&&t.classList.add("hidden"),t.addEventListener("click",function(){const n=document.querySelectorAll(".illustration-item.hidden");for(let o=0;o<l&&o<n.length;o++)n[o].classList.remove("hidden");document.querySelectorAll(".illustration-item.hidden").length===0&&t.classList.add("hidden")})});
